# EmailJS (browser) — used for Contact, Volunteer, Events, and Messaging forms.
# Create a service + template at https://www.emailjs.com/ ; set the template "To" to support@patriotsinaction.com.
# Default app payload matches a “Contact Us” template: name, title, message, time (e.g. subject “Contact Us: {{title}}”).
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=

# Public site URL used for canonical tags, Open Graph URLs, robots.txt, and sitemap.xml.
VITE_SITE_URL=https://patriotsforaction.org
